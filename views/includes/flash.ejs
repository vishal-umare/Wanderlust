<div class="row mt-3">
  <% if (success && success.length) { %>
    <div class="alert alert-success alert-dismissible fade show col-4 offset-4 text-center shadow" role="alert">
      <%= success %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <% if (error && error.length) { %>
    <div class="alert alert-danger alert-dismissible fade show col-4 offset-4 text-center shadow" role="alert">
      <%= error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
</div>